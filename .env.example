# Copy this file to .env and fill in your values
# Never commit .env to version control

# Databricks connection (for remote submission)
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here

# Local paths (used when running outside Databricks)
RAW_DATA_PATH=./data/raw
DELTA_BASE_PATH=./data/delta

# Bronze layer table names
BRONZE_ORDERS_TABLE=bronze_orders
BRONZE_ORDER_ITEMS_TABLE=bronze_order_items
BRONZE_PAYMENTS_TABLE=bronze_order_payments
BRONZE_CUSTOMERS_TABLE=bronze_customers
BRONZE_PRODUCTS_TABLE=bronze_products
BRONZE_AUDIT_TABLE=bronze_ingestion_audit

# Ingestion settings
PIPELINE_ENV=development  # development | staging | production
PIPELINE_VERSION=1.0.0
EXPECTED_ORDERS_MIN_ROWS=90000
EXPECTED_ORDER_ITEMS_MIN_ROWS=110000
